# CarCheck scrapers service — server-side env (copy to scrapers.env on the droplet)
# Generate the auth token with: openssl rand -base64 32
SCRAPERS_AUTH_TOKEN=

# Webshare proxy (provider-agnostic PROXY_* vars)
PROXY_SERVER=http://p.webshare.io:80
PROXY_USERNAME=
PROXY_PASSWORD=

# 2Captcha for CAPTCHA-protected sites (REPUVE, NICB)
TWOCAPTCHA_API_KEY=

# Runtime
PORT=8080
NODE_ENV=production
LOG_LEVEL=info
MAX_CONCURRENT_BROWSERS=2

# Domain Caddy will provision HTTPS for (also export before docker compose up)
SCRAPERS_DOMAIN=scrapers.carcheck.mx
