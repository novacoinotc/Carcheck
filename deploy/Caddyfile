# Caddy auto-provisions HTTPS via Let's Encrypt for the domain below.
# Replace scrapers.carcheck.mx with your actual subdomain (must point an A record
# to this server's public IP before starting Caddy).

{$SCRAPERS_DOMAIN} {
	encode gzip
	reverse_proxy scrapers:8080 {
		health_uri /health
		health_interval 30s
		# Captcha-solving scrapers can run 2-4 min; don't let the proxy cut them off.
		transport http {
			dial_timeout 10s
			read_timeout 300s
			write_timeout 300s
		}
	}
	log {
		output stdout
		format console
	}
}
