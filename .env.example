# ─────────────────────────────────────────────────────────────────────────────
# CarCheck — Environment Variables
# Copy to .env.local for local dev. Production values live in Vercel + Railway.
# Run `vercel env pull .env.local --yes` to sync from Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon, auto-provisioned via Vercel Marketplace) ────────────────
DATABASE_URL=postgres://...
DATABASE_URL_UNPOOLED=postgres://...
POSTGRES_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=

# ─── Cache (Upstash for Redis via Vercel Marketplace) ────────────────────────
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
REDIS_URL=

# ─── Auth (Clerk via Vercel Marketplace) ─────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Storage (Vercel Blob for report PDFs) ───────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── AI (Vercel AI Gateway routing to Anthropic Claude) ──────────────────────
# AI Gateway auto-uses VERCEL_OIDC_TOKEN when deployed on Vercel.
# Set this only when running outside Vercel (local dev) or to override.
AI_GATEWAY_API_KEY=

# ─── External API providers ──────────────────────────────────────────────────
VINAUDIT_API_KEY=
MARKETCHECK_API_KEY=
AUTOCHECK_API_KEY=
BUMPER_API_KEY=
EPICVIN_API_KEY=
CLEARVIN_API_KEY=
SERPAPI_KEY=
TINEYE_API_KEY=
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=

# ─── Scrapers (Railway-hosted Playwright service) ────────────────────────────
# The Vercel app calls these; the Railway service reads them at runtime.
SCRAPERS_BASE_URL=https://carcheck-scrapers-production.up.railway.app
SCRAPERS_AUTH_TOKEN=generate-with-openssl-rand-base64-32
# REPUVE needs 2Captcha to bypass reCAPTCHA. Without it, REPUVE returns "skipped".
TWOCAPTCHA_API_KEY=
# Proxies — provider-agnostic. Webshare rotating endpoint example below.
# Webshare: PROXY_SERVER=http://p.webshare.io:80  PROXY_USERNAME=<user>-rotate
PROXY_SERVER=http://p.webshare.io:80
PROXY_USERNAME=
PROXY_PASSWORD=
# Playwright settings (scrapers service)
MAX_CONCURRENT_BROWSERS=2
LOG_LEVEL=info

# ─── Payments ────────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Mexican partner credentials (Tier 1 once obtained) ──────────────────────
# AMIS / OCRA convention credentials
AMIS_API_KEY=
AMIS_API_SECRET=
# AMDA papel seguridad convention
AMDA_PARTNER_TOKEN=
# VUCEM (e.firma required, usually loaded as file paths)
VUCEM_EFIRMA_CER_PATH=
VUCEM_EFIRMA_KEY_PATH=
VUCEM_EFIRMA_PASSWORD=
# Buró de Crédito SOFOM convention
BURO_CREDITO_API_KEY=

# ─── App config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=novacorp
SENTRY_PROJECT=carcheck
